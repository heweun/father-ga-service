# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CoolSMS (Solapi) - For Individuals (Fallback SMS path)
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
SENDER_PHONE=

# MacroDroid (Galaxy phone SMS dispatch - primary free path)
# Simple shared secret for MacroDroid HTTP action authentication
# Used as query param: GET /api/sms/macrodroid/pending?secret=<value>
# Generate with: openssl rand -hex 32
MACRODROID_WEBHOOK_SECRET=

# Naver OCR (Optional)
NAVER_OCR_URL=
NAVER_OCR_KEY=
